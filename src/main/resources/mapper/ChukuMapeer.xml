<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.bs.mapper.ChukuMapper">

<!--    出库-->
    <insert id="addchuku">
        insert into chuku(leibie,name,client,price,quantity,money,cktime,user)
        values(#{leibie},#{name},#{client},#{price},#{quantity},#{money},#{cktime},#{user})
    </insert>
<!--    查询出库单-->
    <select id="selchuku" resultType="com.example.bs.entity.Chuku">
        select * from chuku
    </select>
    <!-- 查询今日出库单 -->
    <select id="jinchuku" resultType="int">
        SELECT COUNT(*)
        FROM chuku
        WHERE DATE(cktime) = CURDATE()
    </select>

    <!-- 查询今日销售 -->
    <select id="jinsale" resultType="int">
        SELECT IFNULL(SUM(money),0)
        FROM chuku
        WHERE DATE(cktime) = CURDATE()
    </select>

    <!-- 查询本月出库 -->
    <select id="yuechuku" resultType="int">
        SELECT COUNT(*)
        FROM chuku
        WHERE YEAR(cktime)=YEAR(CURDATE())
          AND MONTH(cktime)=MONTH(CURDATE())
    </select>

    <!-- 查询本月销售 -->
    <select id="yuesale" resultType="int">
        SELECT IFNULL(SUM(money),0)
        FROM chuku
        WHERE YEAR(cktime)=YEAR(CURDATE())
          AND MONTH(cktime)=MONTH(CURDATE())
    </select>

    <!-- 查询本年销售 -->
    <select id="yearsale" resultType="int">
        SELECT IFNULL(SUM(money),0)
        FROM chuku
        WHERE YEAR(cktime) = YEAR(CURDATE())
    </select>
<!--    分类查询-->
    <select id="selchuku1" resultType="com.example.bs.entity.Chuku">
        select * from chuku where leibie=#{leibie}
    </select>
<!--    获取所有类别-->
    <select id="selleibie1" resultType="string">
        select DISTINCT leibie from chuku
    </select>
<!--    查询当前用户的出库单-->
    <select id="seluserchuku" resultType="com.example.bs.entity.Chuku">
        select * from chuku where user=#{user}
    </select>
</mapper>

