<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.bs.mapper.KucunMapper">

<!--    查询库存-->
    <select id="selkucun" resultType="com.example.bs.entity.Kucun">
        select * from kucun
    </select>
<!--    添加入库 没有该物品-->
    <insert id="addkucun">
        insert into kucun(code,leibie,name,quantity) values(#{code},#{leibie},#{name},#{quantity})
    </insert>
<!--    添加入库 有该物品,入库-->
    <insert id="upkucun">
        update kucun set quantity=#{quantity} where name=#{name}
    </insert>
<!--    根据name查询库存-->
    <select id="selname" resultType="com.example.bs.entity.Kucun">
        select * from kucun where name=#{name}
    </select>
<!--    分类查询-->
    <select id="selleibie" resultType="com.example.bs.entity.Kucun">
        select * from kucun where leibie=#{leibie}
    </select>
<!--    获取所有类别-->
    <select id="selleibie2" resultType="string">
        select distinct leibie from kucun
    </select>
<!--    根据code查询物品，获取leibie和name-->
    <select id="selcode" resultType="com.example.bs.entity.Kucun">
        select leibie, name from kucun where code=#{code}
    </select>
<!--    根据id对库存表进行动态修改（修改code，leibie，name，quantity）-->
    <update id="upkucun2">
        update kucun
        <set>
            <if test="code != null">code=#{code},</if>
            <if test="leibie != null">leibie=#{leibie},</if>
            <if test="name != null">name=#{name},</if>
            <if test="quantity != null">quantity=#{quantity},</if>
        </set>
        where id=#{id}
    </update>



</mapper>