<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.bs.mapper.XinxiMapper">
<!--    查询通知-->
    <select id="selxinxi" resultType="com.example.bs.entity.Xinxi">
        select * from xinxi
    </select>
<!--添加通知-->
    <insert id="addxinxi">
        insert into xinxi(title,text,priority,crtime) values(#{title},#{text},#{priority},#{crtime})
    </insert>
<!--删除通知-->
    <delete id="delxinxi">
        delete from xinxi where id = #{id}
    </delete>
<!--修改通知-->
    <update id="upxinxi">
        update xinxi
        <set>
            <if test="title != null and title != ''">
                title = #{title},
            </if>
            <if test="text != null and text != ''">
                text = #{text},
            </if>
            <if test="priority != null">
                priority = #{priority},
            </if>
        </set>
        where id = #{id}
    </update>
</mapper>
